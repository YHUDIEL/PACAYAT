generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// ─────────────────────────────────────────
// ROLES Y USUARIOS
// ─────────────────────────────────────────

model RolSistema {
  id_rol      Int          @id @default(autoincrement())
  nombre      String       @unique
  descripcion String?
  usuarios    UsuarioRol[]

  @@map("rol_sistema")
}

model Usuario {
  id_usuario    Int          @id @default(autoincrement())
  username      String       @unique
  password      String
  fecha_creacion DateTime    @default(now())
  activo        Boolean      @default(true)

  id_tutor      Int?
  id_personal   Int?

  tutor         Tutor?       @relation(fields: [id_tutor], references: [id_tutor])
  personal      Personal?    @relation(fields: [id_personal], references: [id_personal])
  roles         UsuarioRol[]

  @@map("usuario")
}

model UsuarioRol {
  id_usuario  Int
  id_rol      Int
  created_at  DateTime   @default(now())

  usuario     Usuario    @relation(fields: [id_usuario], references: [id_usuario])
  rol         RolSistema @relation(fields: [id_rol], references: [id_rol])

  @@id([id_usuario, id_rol])
  @@map("usuario_rol")
}

// ─────────────────────────────────────────
// PERSONAL
// ─────────────────────────────────────────

model Personal {
  id_personal       Int          @id @default(autoincrement())
  nombre            String
  apellido_paterno  String
  apellido_materno  String?
  rol_tipo          String
  activo            Boolean      @default(true)
  telefono          String?
  correo            String?

  usuario           Usuario[]
  reportes          Reporte[]
  asignaciones      Asignacion[]

  @@map("personal")
}

// ─────────────────────────────────────────
// TUTORES Y ALUMNOS
// ─────────────────────────────────────────

model Tutor {
  id_tutor          Int           @id @default(autoincrement())
  nombre            String
  apellido_paterno  String
  apellido_materno  String?
  parentesco        String?
  telefono          String?
  correo            String?

  usuario           Usuario[]
  alumnos           TutorAlumno[]

  @@map("tutor")
}

model TutorAlumno {
  id_tutor    Int
  id_alumno   Int
  principal   Boolean   @default(false)

  tutor       Tutor     @relation(fields: [id_tutor], references: [id_tutor])
  alumno      Alumno    @relation(fields: [id_alumno], references: [id_alumno])

  @@id([id_tutor, id_alumno])
  @@map("tutor_alumno")
}

model Alumno {
  id_alumno         Int           @id @default(autoincrement())
  matricula         String        @unique
  nombre            String
  apellido_paterno  String
  apellido_materno  String?
  curp              String?       @unique
  activo            Boolean       @default(true)
  puntos_conducta   Int           @default(100)

  tutores           TutorAlumno[]
  inscripciones     Inscripcion[]
  archivos          ArchivoAlumno[]

  @@map("alumno")
}

// ─────────────────────────────────────────
// GRUPOS, PERIODOS E INSCRIPCIONES
// ─────────────────────────────────────────

model Grupo {
  id_grupo      Int           @id @default(autoincrement())
  grado         Int
  grupo         String
  turno         String?

  inscripciones Inscripcion[]
  asignaciones  Asignacion[]

  @@map("grupo")
}

model Periodo {
  id_periodo    Int           @id @default(autoincrement())
  nombre        String
  anio          Int
  activo        Boolean       @default(false)
  fecha_inicio  DateTime
  fecha_fin     DateTime

  inscripciones Inscripcion[]
  asignaciones  Asignacion[]

  @@map("periodo")
}

model Inscripcion {
  id_inscripcion    Int                @id @default(autoincrement())
  id_alumno         Int
  id_grupo          Int
  id_periodo        Int

  alumno            Alumno             @relation(fields: [id_alumno], references: [id_alumno])
  grupo             Grupo              @relation(fields: [id_grupo], references: [id_grupo])
  periodo           Periodo            @relation(fields: [id_periodo], references: [id_periodo])

  evaluaciones_riesgo EvaluacionRiesgo[]
  reportes            Reporte[]
  calificaciones      Calificacion[]
  asistencias         Asistencia[]

  @@map("inscripcion")
}

// ─────────────────────────────────────────
// MATERIAS Y ASIGNACIONES
// ─────────────────────────────────────────

model Materia {
  id_materia    Int           @id @default(autoincrement())
  clave         String        @unique
  nombre        String
  grado         Int

  asignaciones  Asignacion[]

  @@map("materia")
}

model Asignacion {
  id_asignacion Int           @id @default(autoincrement())
  id_grupo      Int
  id_personal   Int
  id_materia    Int
  id_periodo    Int

  grupo         Grupo         @relation(fields: [id_grupo], references: [id_grupo])
  personal      Personal      @relation(fields: [id_personal], references: [id_personal])
  materia       Materia       @relation(fields: [id_materia], references: [id_materia])
  periodo       Periodo       @relation(fields: [id_periodo], references: [id_periodo])

  calificaciones Calificacion[]
  asistencias    Asistencia[]

  @@map("asignacion")
}

// ─────────────────────────────────────────
// EVALUACIONES Y CALIFICACIONES
// ─────────────────────────────────────────

model CatalogoEvaluacion {
  id_catalogo_evaluacion  Int                  @id @default(autoincrement())
  nombre                  String
  numero_periodos         Int

  periodos_evaluacion     PeriodoEvaluacion[]

  @@map("catalogo_evaluacion")
}

model PeriodoEvaluacion {
  id_periodo_evaluacion     Int                  @id @default(autoincrement())
  nombre                    String
  fecha_inicio              DateTime
  fecha_fin                 DateTime
  activo                    Boolean              @default(false)
  id_catalogo_evaluacion    Int

  catalogo                  CatalogoEvaluacion   @relation(fields: [id_catalogo_evaluacion], references: [id_catalogo_evaluacion])
  calificaciones            Calificacion[]

  @@map("periodo_evaluacion")
}

model Calificacion {
  id_calificacion       Int               @id @default(autoincrement())
  calificacion          Float?
  id_asignacion         Int
  id_inscripcion        Int
  id_periodo_evaluacion Int

  asignacion            Asignacion        @relation(fields: [id_asignacion], references: [id_asignacion])
  inscripcion           Inscripcion       @relation(fields: [id_inscripcion], references: [id_inscripcion])
  periodo_evaluacion    PeriodoEvaluacion @relation(fields: [id_periodo_evaluacion], references: [id_periodo_evaluacion])

  @@unique([id_asignacion, id_inscripcion, id_periodo_evaluacion])
  @@map("calificacion")
}

// ─────────────────────────────────────────
// ASISTENCIA
// ─────────────────────────────────────────

model Asistencia {
  id_asistencia   Int         @id @default(autoincrement())
  fecha           DateTime    @db.Date
  estado          String      // PRESENTE | FALTA | RETARDO
  id_asignacion   Int
  id_inscripcion  Int

  asignacion      Asignacion  @relation(fields: [id_asignacion], references: [id_asignacion])
  inscripcion     Inscripcion @relation(fields: [id_inscripcion], references: [id_inscripcion])

  @@unique([fecha, id_asignacion, id_inscripcion])
  @@map("asistencia")
}

// ─────────────────────────────────────────
// REPORTES DE CONDUCTA
// ─────────────────────────────────────────

model Reporte {
  id_reporte      Int         @id @default(autoincrement())
  tipo            String      // POSITIVO | NEGATIVO
  categoria       String      // GRAVE | MEDIO | NO_GRAVE | POSITIVO | MEDIANAMENTE_POSITIVO | MUY_POSITIVO
  puntos          Int         // valor que se suma o resta
  descripcion     String
  fecha           DateTime    @default(now())
  id_personal     Int
  id_inscripcion  Int

  personal        Personal    @relation(fields: [id_personal], references: [id_personal])
  inscripcion     Inscripcion @relation(fields: [id_inscripcion], references: [id_inscripcion])

  @@map("reporte")
}

// ─────────────────────────────────────────
// RIESGO ACADÉMICO
// ─────────────────────────────────────────

model CatalogoRiesgo {
  id_catalogo_riesgo  Int                @id @default(autoincrement())
  nombre              String
  descripcion         String?
  nivel               Int

  evaluaciones        EvaluacionRiesgo[]

  @@map("catalogo_riesgo")
}

model EvaluacionRiesgo {
  id_evaluacion_riesgo  Int             @id @default(autoincrement())
  fecha                 DateTime        @default(now())
  id_catalogo_riesgo    Int
  id_inscripcion        Int

  catalogo_riesgo       CatalogoRiesgo  @relation(fields: [id_catalogo_riesgo], references: [id_catalogo_riesgo])
  inscripcion           Inscripcion     @relation(fields: [id_inscripcion], references: [id_inscripcion])

  @@map("evaluacion_riesgo")
}

// ─────────────────────────────────────────
// AVISOS Y NOTIFICACIONES
// ─────────────────────────────────────────

model Aviso {
  id_aviso        Int       @id @default(autoincrement())
  titulo          String
  contenido       String
  tipo            String    // PERIODO_EVALUACION | REINSCRIPCION | CONDUCTA | GENERAL
  activo          Boolean   @default(true)
  umbral_conducta Int?      // si tipo=CONDUCTA, puntos en los que se dispara
  fecha_creacion  DateTime  @default(now())
  creado_por      Int       // id_personal del admin

  notificaciones  Notificacion[]

  @@map("aviso")
}

model Notificacion {
  id_notificacion Int       @id @default(autoincrement())
  id_aviso        Int
  id_usuario      Int       // destinatario
  leida           Boolean   @default(false)
  fecha_envio     DateTime  @default(now())
  canal           String    // PLATAFORMA | WHATSAPP | CORREO

  aviso           Aviso     @relation(fields: [id_aviso], references: [id_aviso])

  @@map("notificacion")
}

// ─────────────────────────────────────────
// ARCHIVOS POR ALUMNO (Secretaría)
// ─────────────────────────────────────────

model ArchivoAlumno {
  id_archivo      Int       @id @default(autoincrement())
  id_alumno       Int
  nombre          String
  ruta            String
  tipo_mime       String?
  fecha_subida    DateTime  @default(now())
  subido_por      Int       // id_personal

  alumno          Alumno    @relation(fields: [id_alumno], references: [id_alumno])

  @@map("archivo_alumno")
}