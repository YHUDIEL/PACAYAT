// PACAYAT - Schema Prisma para PostgreSQL 17
// Ejecutar: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ──────────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  DIRECTIVO
  DOCENTE
  PREFECTO
  SECRETARIA
  CONTROL_ESCOLAR
  TUTOR
}

enum TipoReporte {
  POSITIVO
  NEGATIVO
}

enum GravedadReporte {
  GRAVE
  MEDIO
  NO_GRAVE
  MUY_POSITIVO
  MEDIANAMENTE
  LEVE
}

enum EstadoAsistencia {
  PRESENTE
  FALTA
  RETARDO
}

enum TipoAviso {
  CONDUCTA
  PERIODO_EVALUACION
  REINSCRIPCION
  GENERAL
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
}

// ── MODELOS ────────────────────────────────────────────────────────────────

model Usuario {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  nombre        String   @map("nombre_completo")
  password      String   @map("password_hash")
  rol           Rol
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("created_at")
  actualizadoEn DateTime @updatedAt @map("updated_at")

  personal        Personal?
  tutor           Tutor?
  reportes        Reporte[]
  avisosEnviados  AvisoEnviado[]
  archivosSubidos ArchivoAlumno[]

  @@map("usuarios")
}

model PeriodoEscolar {
  id          Int      @id @default(autoincrement())
  nombre      String
  fechaInicio DateTime @map("fecha_inicio")
  fechaFin    DateTime @map("fecha_fin")
  activo      Boolean  @default(false)
  creadoEn    DateTime @default(now()) @map("created_at")

  inscripciones Inscripcion[]

  @@map("periodos_escolares")
}

model PeriodoEvaluacion {
  id          Int      @id @default(autoincrement())
  nombre      String
  fechaInicio DateTime @map("fecha_inicio")
  fechaFin    DateTime @map("fecha_fin")
  creadoEn    DateTime @default(now()) @map("created_at")

  calificaciones Calificacion[]

  @@map("periodos_evaluacion")
}

model PeriodoReinscripcion {
  id          Int      @id @default(autoincrement())
  fechaInicio DateTime @map("fecha_inicio")
  fechaFin    DateTime @map("fecha_fin")
  activo      Boolean  @default(false)
  creadoEn    DateTime @default(now()) @map("created_at")

  @@map("periodos_reinscripcion")
}

model Grupo {
  id      Int    @id @default(autoincrement())
  nombre  String @unique
  grado   Int
  seccion String

  alumnos       Alumno[]
  asignaciones  Asignacion[]
  inscripciones Inscripcion[]

  @@map("grupos")
}

model Materia {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  clave  String? @unique

  asignaciones Asignacion[]

  @@map("materias")
}

model Personal {
  id        Int      @id @default(autoincrement())
  nombre    String   @map("nombre_completo")
  rol       Rol
  telefono  String?
  correo    String?
  curp      String?
  activo    Boolean  @default(true)
  idUsuario Int      @unique @map("id_usuario")
  creadoEn  DateTime @default(now()) @map("created_at")

  usuario      Usuario     @relation(fields: [idUsuario], references: [id])
  asignaciones Asignacion[]

  @@map("personal")
}

model Tutor {
  id             Int      @id @default(autoincrement())
  nombreCompleto String   @map("nombre_completo")
  telefono       String?
  correo         String?
  idUsuario      Int      @unique @map("id_usuario")
  creadoEn       DateTime @default(now()) @map("created_at")

  usuario Usuario  @relation(fields: [idUsuario], references: [id])
  alumnos Alumno[]

  @@map("tutores")
}

model Alumno {
  id              Int       @id @default(autoincrement())
  nombreCompleto  String    @map("nombre_completo")
  matricula       String    @unique
  curp            String?
  fechaNacimiento DateTime? @map("fecha_nacimiento")
  domicilio       String?   @map("direccion")
  puntosConducta  Int       @default(100) @map("puntos_conducta")
  activo          Boolean   @default(true)
  idGrupo         Int       @map("id_grupo")
  idTutor         Int?      @map("id_tutor")
  creadoEn        DateTime  @default(now()) @map("created_at")
  actualizadoEn   DateTime  @updatedAt @map("updated_at")

  grupo         Grupo           @relation(fields: [idGrupo], references: [id])
  tutor         Tutor?          @relation(fields: [idTutor], references: [id])
  inscripciones Inscripcion[]
  reportes      Reporte[]
  archivos      ArchivoAlumno[]

  @@map("alumnos")
}

model Inscripcion {
  id               Int      @id @default(autoincrement())
  idAlumno         Int      @map("id_alumno")
  idPeriodoEscolar Int      @map("id_periodo_escolar")
  idGrupo          Int?     @map("id_grupo")
  activa           Boolean  @default(true) @map("activo")
  creadoEn         DateTime @default(now()) @map("created_at")

  alumno         Alumno         @relation(fields: [idAlumno], references: [id])
  periodoEscolar PeriodoEscolar @relation(fields: [idPeriodoEscolar], references: [id])
  grupo          Grupo?         @relation(fields: [idGrupo], references: [id])
  calificaciones Calificacion[]
  asistencias    Asistencia[]
  reportes       Reporte[]

  @@unique([idAlumno, idPeriodoEscolar])
  @@map("inscripciones")
}

model Asignacion {
  id        Int      @id @default(autoincrement())
  idDocente Int      @map("id_docente")
  idMateria Int      @map("id_materia")
  idGrupo   Int      @map("id_grupo")
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("created_at")

  docente        Personal       @relation(fields: [idDocente], references: [id])
  materia        Materia        @relation(fields: [idMateria], references: [id])
  grupo          Grupo          @relation(fields: [idGrupo], references: [id])
  horarios       Horario[]
  calificaciones Calificacion[]
  asistencias    Asistencia[]

  @@unique([idDocente, idMateria, idGrupo])
  @@map("asignaciones")
}

model Horario {
  id           Int       @id @default(autoincrement())
  idAsignacion Int       @map("id_asignacion")
  dia          DiaSemana
  numeroClase  Int       @map("numero_clase") // 1-9 (receso se maneja en frontend)
  salon        String?

  asignacion Asignacion @relation(fields: [idAsignacion], references: [id])

  @@unique([idAsignacion, dia, numeroClase])
  @@map("horarios")
}

model Reporte {
  id               Int             @id @default(autoincrement())
  idAlumno         Int             @map("id_alumno")
  idInscripcion    Int?            @map("id_inscripcion")
  idUsuarioReporta Int             @map("id_usuario_reporta")
  tipo             TipoReporte
  gravedad         GravedadReporte
  descripcion      String
  puntosAntes      Int             @map("puntos_antes")
  puntosDespues    Int             @map("puntos_despues")
  creadoEn         DateTime        @default(now()) @map("created_at")

  alumno         Alumno       @relation(fields: [idAlumno], references: [id])
  inscripcion    Inscripcion? @relation(fields: [idInscripcion], references: [id])
  usuarioReporta Usuario      @relation(fields: [idUsuarioReporta], references: [id])

  @@map("reportes")
}

model Calificacion {
  id            Int      @id @default(autoincrement())
  idInscripcion Int      @map("id_inscripcion")
  idAsignacion  Int      @map("id_asignacion")
  idPeriodo     Int      @map("id_periodo")
  calificacion  Float
  creadoEn      DateTime @default(now()) @map("created_at")
  actualizadoEn DateTime @updatedAt @map("updated_at")

  inscripcion Inscripcion       @relation(fields: [idInscripcion], references: [id])
  asignacion  Asignacion        @relation(fields: [idAsignacion], references: [id])
  periodo     PeriodoEvaluacion @relation(fields: [idPeriodo], references: [id])

  @@unique([idInscripcion, idAsignacion, idPeriodo])
  @@map("calificaciones")
}

model Asistencia {
  id            Int              @id @default(autoincrement())
  idInscripcion Int              @map("id_inscripcion")
  idAsignacion  Int              @map("id_asignacion")
  fecha         DateTime         @db.Date
  estado        EstadoAsistencia
  creadoEn      DateTime         @default(now()) @map("created_at")

  inscripcion Inscripcion @relation(fields: [idInscripcion], references: [id])
  asignacion  Asignacion  @relation(fields: [idAsignacion], references: [id])

  @@unique([idInscripcion, idAsignacion, fecha])
  @@map("asistencias")
}

model Aviso {
  id           Int       @id @default(autoincrement())
  tipo         TipoAviso
  titulo       String
  mensaje      String
  umbralPuntos Int?      @map("umbral_puntos") // Solo para CONDUCTA
  canales      String[]  // ["WHATSAPP", "CORREO", "PLATAFORMA"]
  activo       Boolean   @default(true)
  creadoEn     DateTime  @default(now()) @map("created_at")

  enviados AvisoEnviado[]

  @@map("avisos")
}

model AvisoEnviado {
  id        Int      @id @default(autoincrement())
  idAviso   Int      @map("id_aviso")
  idUsuario Int?     @map("id_usuario") // Receptor general (docente/tutor)
  idTutor   Int?     @map("id_tutor")   // Para avisos de conducta
  idAlumno  Int?     @map("id_alumno")  // Alumno que disparó el aviso
  canal     String
  enviadoEn DateTime @default(now()) @map("enviado_at")

  aviso   Aviso    @relation(fields: [idAviso], references: [id])
  usuario Usuario? @relation(fields: [idUsuario], references: [id])

  @@map("avisos_enviados")
}

model ArchivoAlumno {
  id        Int      @id @default(autoincrement())
  idAlumno  Int      @map("id_alumno")
  nombre    String
  ruta      String
  tipo      String   // mimetype
  tamanio   Int      // bytes
  subidoPor Int      @map("subido_por")
  creadoEn  DateTime @default(now()) @map("created_at")

  alumno           Alumno  @relation(fields: [idAlumno], references: [id])
  subidoPorUsuario Usuario @relation(fields: [subidoPor], references: [id])

  @@map("archivos_alumnos")
}

model ConfiguracionEscuela {
  id            Int      @id @default(1)
  nombre        String   @default("Secundaria Técnica 177")
  direccion     String?
  telefono      String?
  correo        String?
  director      String?
  actualizadoEn DateTime @updatedAt @map("updated_at")

  @@map("configuracion_escuela")
}
